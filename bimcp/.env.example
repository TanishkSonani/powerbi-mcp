# Copy this file to .env and adjust values as needed.
# Phase 1 — no required env vars. Included for Phase 2+ readiness.

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Phase 2+: override the default resources/md/ directory
# RESOURCE_DIR=C:\path\to\custom\md

# Phase 3+: manually override the Power BI Desktop workspace root
# PBI_WORKSPACE_ROOT=C:\Users\you\AppData\Local\Microsoft\Power BI Desktop\AnalysisServicesWorkspaces
